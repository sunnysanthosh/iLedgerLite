# API service URLs — copy this file to .env.local and adjust for your environment.
# .env.local is git-ignored; never commit it.
#
# Local dev defaults (Docker Compose)

# ── Admin access control ─────────────────────────────────────────────────────
# ADMIN_EMAILS (server-only, no NEXT_PUBLIC_ prefix — stays secret on the server)
# Used by /api/infra/costs route handler to authorise admin access server-side.
# Comma-separated list of email addresses that can view the Infra Costs page.
# ADMIN_EMAILS=founder@ledgerlite.app,ops@ledgerlite.app

# AUTH_URL (server-only) — used by /api/infra/costs to call auth-service /me.
# In K8s set to the internal service URL (e.g. http://auth-service:8000).
# Falls back to NEXT_PUBLIC_AUTH_URL if unset (sufficient for local dev).
# AUTH_URL=http://auth-service:8000

# NEXT_PUBLIC_ADMIN_EMAILS — client-side hint for hiding the Infra Costs nav item.
# This is visible in the browser JS bundle; security is enforced server-side above.
# NEXT_PUBLIC_ADMIN_EMAILS=founder@ledgerlite.app,ops@ledgerlite.app

NEXT_PUBLIC_AUTH_URL=http://localhost:8001
NEXT_PUBLIC_USER_URL=http://localhost:8002
NEXT_PUBLIC_TXN_URL=http://localhost:8003
NEXT_PUBLIC_LEDGER_URL=http://localhost:8004
NEXT_PUBLIC_REPORT_URL=http://localhost:8005
NEXT_PUBLIC_AI_URL=http://localhost:8006
NEXT_PUBLIC_NOTIFICATION_URL=http://localhost:8007
NEXT_PUBLIC_SYNC_URL=http://localhost:8008
